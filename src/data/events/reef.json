            "slot": "tool"
          },
          "outcome": {
            "text": "刀出鞘的一瞬，刃面闪了一下——它等的就是这一下。银线射过来。",
            "triggerCombatId": "combat.reef_barracuda_solo"
          }
        },
        {
          "id": "go_still",
