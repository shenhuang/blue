{
  "events": [
    {
      "id": "reef.kelp_curtain",
      "depthRange": [10, 25],
      "zoneTags": ["shallow", "reef"],
      "weight": 10,
      "cooldown": 3,
      "title": "海藻帘子",
      "body": "一片厚厚的海藻随海流缓缓摆动。\n光线穿不透，但下面似乎有动静。",
      "tone": "realistic",
      "options": [
        {
          "id": "push_through",
          "label": "推开海藻穿过去（体力 -3）",
          "outcome": {
            "text": "海藻黏腻地贴在面镜上。你拨开它，看见两只龙虾。它们也看见了你。",
            "deltas": { "stamina": -3 },
            "loot": [
              { "itemId": "item.lobster", "qty": [1, 2], "chance": 0.7 }
            ]
          }
        },
        {
          "id": "swim_around",
          "label": "绕开（氧气 -2）",
          "outcome": {
            "text": "你绕了一大圈。安全，但更累。",
            "oxygenTurnCost": 2
          }
        }
      ]
    },

    {
      "id": "reef.lobster_hole",
      "depthRange": [15, 35],
      "zoneTags": ["reef"],
      "weight": 8,
      "cooldown": 4,
      "title": "礁洞",
      "body": "礁石上一个深洞。一对触须正一伸一缩地试探着外面。",
      "tone": "realistic",
      "options": [
        {
          "id": "grab",
          "label": "伸手去抓",
          "check": {
            "stat": "stamina",
            "dc": 12,
            "onSuccess": {
              "text": "你手很稳。它没来得及缩回去。",
              "loot": [{ "itemId": "item.lobster", "qty": [1, 1] }]
            },
            "onFailure": {
              "text": "它夹住你的指根。一阵剧痛，你抽回手。",
              "deltas": { "stamina": -5 }
            }
          }
        },
        {
          "id": "wait_with_knife",
          "label": "握刀等它出来",
          "visibleIf": { "kind": "hasEquipment", "slot": "tool" },
          "outcome": {
            "text": "你压住浮力，让自己沉下来。两个回合后它探出来——刀落下，干净利落。",
            "oxygenTurnCost": 2,
            "loot": [{ "itemId": "item.lobster", "qty": [1, 2] }]
          }
        },
        {
          "id": "leave",
          "label": "算了，走吧",
          "outcome": {
            "text": "你继续向前。"
          }
        }
      ]
    },

    {
      "id": "reef.current_drag",
      "depthRange": [10, 30],
      "zoneTags": ["reef", "wreck"],
      "weight": 6,
      "title": "逆流",
      "body": "你感到水流变了方向。\n如果不抓住什么，会被往深处推。",
      "tone": "realistic",
      "options": [
        {
          "id": "anchor",
          "label": "扒住礁石（体力 -8）",
          "outcome": {
            "text": "你死死抓住礁石的硬枝，过了一阵，水流过去了。",
            "deltas": { "stamina": -8 }
          }
        },
        {
          "id": "drift",
          "label": "顺流而下（深度自然加深）",
          "outcome": {
            "text": "你松弛下来，让水带你走。它没把你带到太远，但你呼吸有点乱。",
            "oxygenTurnCost": 2,
            "deltas": { "nitrogen": 4 }
          }
        }
      ]
    },

    {
      "id": "wreck.fishing_boat",
      "depthRange": [25, 45],
      "zoneTags": ["wreck"],
      "weight": 10,
      "cooldown": 4,
      "title": "渔船残骸",
      "body": "一艘翻覆的小渔船半埋在沙里。\n船舷上还挂着没被撕烂的渔网。",
      "tone": "realistic",
      "options": [
        {
          "id": "salvage_net",
          "label": "切下渔网（潜水刀）",
          "visibleIf": { "kind": "hasEquipment", "slot": "tool" },
          "outcome": {
            "text": "刀刃进的时候，网线像是叹了口气。",
            "oxygenTurnCost": 1,
            "loot": [{ "itemId": "item.old_fishing_net", "qty": [1, 1] }]
          }
        },
        {
          "id": "enter_cabin",
          "label": "钻进船舱看看",
          "outcome": {
            "text": "舱里很黑。你的灯照到一个铁皮罐——盖子还没锈穿。",
            "oxygenTurnCost": 2,
            "loot": [
              { "itemId": "item.canned_food", "qty": [1, 2], "chance": 0.8 }
            ]
          }
        },
        {
          "id": "skip",
          "label": "不感兴趣，离开",
          "outcome": { "text": "你绕过它，继续向前。" }
        }
      ]
    },

    {
      "id": "wreck.compass",
      "depthRange": [25, 50],
      "zoneTags": ["wreck"],
      "weight": 4,
      "oncePerRun": true,
      "title": "还在转的指南针",
      "body": "锈成一坨的小方盒，盖子半开。\n指针指着南——不对，是西南——\n它在转。在水里，缓慢地转。",
      "tone": "uncanny",
      "options": [
        {
          "id": "take",
          "label": "拿走",
          "outcome": {
            "text": "你把它塞进网袋。它在你腰间继续转。",
            "loot": [{ "itemId": "item.rusty_compass", "qty": [1, 1] }],
            "deltas": { "sanity": -3 }
          }
        },
        {
          "id": "leave",
          "label": "不要",
          "outcome": {
            "text": "你看了它一会儿，转身。"
          }
        }
      ]
    },

    {
      "id": "cave.narrow_passage",
      "depthRange": [40, 55],
      "zoneTags": ["cave"],
      "weight": 6,
      "title": "狭窄通道",
      "body": "礁石间一条裂缝，刚够你侧着挤进去。\n灯光照进去，照不到底。",
      "tone": "uncanny",
      "options": [
        {
          "id": "squeeze",
          "label": "侧身挤过去",
          "check": {
            "stat": "stamina",
            "dc": 14,
            "onSuccess": {
              "text": "你蹭着石壁过去。另一边豁然开朗——是个小小的礁洞，沙里有什么在闪。",
              "oxygenTurnCost": 2,
              "loot": [
                { "itemId": "item.coral_shard", "qty": [1, 2] },
                { "itemId": "item.rusty_compass", "qty": [1, 1], "chance": 0.1 }
              ]
            },
            "onFailure": {
              "text": "你卡了一下。挣脱的时候气瓶撞到岩壁，发出一声闷响。\n你听见自己心跳。",
              "deltas": { "stamina": -8, "sanity": -3 },
              "oxygenTurnCost": 3
            }
          }
        },
        {
          "id": "skip",
          "label": "算了，太窄",
          "outcome": { "text": "你向旁边游开。" }
        }
      ]
    },

    {
      "id": "cave.air_pocket",
      "depthRange": [30, 55],
      "zoneTags": ["cave"],
      "weight": 3,
      "oncePerRun": true,
      "title": "气穴",
      "body": "礁顶的一道裂缝里——\n你的灯照上去，水面在晃。\n这里有个气穴。",
      "tone": "realistic",
      "options": [
        {
          "id": "breathe",
          "label": "上去呼吸（氧气 +6 回合）",
          "outcome": {
            "text": "你的头露出水面。空气有股陈年的金属味，但能用。\n你深深吸了几口。",
            "deltas": { "oxygen": 6, "sanity": 4 }
          }
        },
        {
          "id": "ignore",
          "label": "保持下潜，记住位置",
          "outcome": {
            "text": "你看了一眼水面，继续向下。"
          }
        }
      ]
    },

    {
      "id": "cave.glowing_eyes",
      "depthRange": [45, 60],
      "zoneTags": ["cave"],
      "weight": 5,
      "sanityRange": [0, 90],
      "title": "黑暗里的东西",
      "body": "你的灯扫过岩石——\n有两点光在岩石深处一闪。\n你的灯关了又开。它们没了。\n然后又出现。",
      "tone": "uncanny",
      "options": [
        {
          "id": "approach",
          "label": "靠近看清楚",
          "check": {
            "stat": "sanity",
            "dc": 60,
            "onSuccess": {
              "text": "是两块磷光的菌斑。岩石上的。怪是怪，但解释得通。",
              "deltas": { "sanity": -2 }
            },
            "onFailure": {
              "text": "你越靠近，它越深。等你回过神，你已经在岩缝里游了三分钟。",
              "deltas": { "sanity": -8 },
              "oxygenTurnCost": 3
            }
          }
        },
        {
          "id": "retreat",
          "label": "立刻退开",
          "outcome": {
            "text": "你向后游。气泡掩盖了你最后一眼瞥见的东西。",
            "deltas": { "sanity": -1 }
          }
        }
      ]
    },

    {
      "id": "reef.flooded_stair",
      "depthRange": [10, 24],
      "zoneTags": ["shallow", "reef"],
      "weight": 8,
      "cooldown": 3,
      "title": "灌满水的旋梯",
      "body": "灯塔的铁旋梯从礁顶斜插下来，灌满了水。\n二十年的藻把扶手包成了软的。\n梯口卡着一扇锈死的铁格栅。",
      "tone": "realistic",
      "options": [
        {
          "id": "pry_grate",
          "label": "撬开格栅（体力 vs 12）",
          "check": {
            "stat": "stamina",
            "dc": 12,
            "onSuccess": {
              "text": "锈层崩开。后面是看守人存渔具的小柜，黄铜活页还转得动。",
              "oxygenTurnCost": 1,
              "loot": [
                { "itemId": "item.brass_fitting", "qty": [1, 1] },
                { "itemId": "item.coral_shard", "qty": [1, 1], "chance": 0.5 }
              ]
            },
            "onFailure": {
              "text": "格栅纹丝不动。你撬到手腕发酸。",
              "deltas": { "stamina": -5 }
            }
          }
        },
        {
          "id": "descend",
          "label": "顺着旋梯往下",
          "outcome": {
            "text": "你扶着梯往下游。光一节一节地暗下去。",
            "oxygenTurnCost": 2,
            "loot": [{ "itemId": "item.coral_shard", "qty": [1, 2], "chance": 0.6 }]
          }
        },
        {
          "id": "leave",
          "label": "回到礁面",
          "outcome": { "text": "你离开梯口。" }
        }
      ]
    },

    {
      "id": "reef.keepers_footlocker",
      "depthRange": [12, 26],
      "zoneTags": ["shallow", "reef"],
      "weight": 4,
      "oncePerRun": true,
      "title": "看守人的箱子",
      "body": "礁石缝里楔着一只木箱——\n灯塔看守人的，铜锁早烂穿了。\n盖子下面压着没被泡烂的东西。",
      "tone": "realistic",
      "options": [
        {
          "id": "open_it",
          "label": "撬开盖子",
          "outcome": {
            "text": "一听没开的罐头、半盒受潮的火柴、一张泡得只剩边框的照片。\n你认不出照片上的人。",
            "oxygenTurnCost": 1,
            "loot": [
              { "itemId": "item.canned_food", "qty": [1, 1] },
              { "itemId": "item.brass_fitting", "qty": [1, 1], "chance": 0.5 }
            ],
            "loreEntry": "lore.old_lighthouse.keeper"
          }
        },
        {
          "id": "leave",
          "label": "盖回去",
          "outcome": {
            "text": "你把盖子按回去。让他留着。",
            "deltas": { "sanity": -1 }
          }
        }
      ]
    },

    {
      "id": "reef.bleached_garden",
      "depthRange": [16, 32],
      "zoneTags": ["reef"],
      "weight": 6,
      "cooldown": 4,
      "title": "白的那一片",
      "body": "前面一片珊瑚是白的。\n不是病那种脏白——是干净的、骨头一样的白。\n而且排得太齐，像谁摆过。",
      "tone": "uncanny",
      "options": [
        {
          "id": "break_piece",
          "label": "掰一块下来",
          "outcome": {
            "text": "白珊瑚是凉的，掰起来像粉笔。\n断口太平整，不像掰断的。",
            "loot": [{ "itemId": "item.coral_shard", "qty": [1, 2] }],
            "deltas": { "sanity": -2 }
          }
        },
        {
          "id": "leave_it",
          "label": "不碰，绕过去",
          "outcome": {
            "text": "你绕开那片白。它在灯里像一排摆错了位置的牙。",
            "deltas": { "sanity": -1 }
          }
        }
      ]
    },

    {
      "id": "reef.fog_bell",
      "depthRange": [20, 38],
      "zoneTags": ["reef"],
      "weight": 4,
      "oncePerRun": true,
      "title": "雾钟",
      "body": "灯塔的雾钟翻在沙里，钟口朝着你。\n每次水流过，钟就晃一下——\n你不是听见，是胸口先感到那一下。",
      "tone": "uncanny",
      "options": [
        {
          "id": "still_it",
          "label": "按住钟，让它停（体力 vs 13）",
          "check": {
            "stat": "stamina",
            "dc": 13,
            "onSuccess": {
              "text": "你两手抱住钟身。它安静下来。水里一下子空了，连呼吸都显得太响。",
              "oxygenTurnCost": 1,
              "loot": [{ "itemId": "item.brass_fitting", "qty": [1, 1] }]
            },
            "onFailure": {
              "text": "钟太重。钟舌甩出去，撞在沉船的钢板上。那一声穿过你整个人。",
              "deltas": { "sanity": -6 },
              "oxygenTurnCost": 2
            }
          }
        },
        {
          "id": "listen",
          "label": "停下来，听它响",
          "outcome": {
            "text": "你停在原地。钟一下、一下地响，间隔和你的心跳错开半拍。\n你忽然记起一个不属于你的号牌。",
            "deltas": { "sanity": -4 },
            "oxygenTurnCost": 1,
            "loreEntry": "lore.old_lighthouse.bell"
          }
        },
        {
          "id": "swim_clear",
          "label": "快游开",
          "outcome": {
            "text": "你蹬腿离开。那一下、一下，跟了你一段。",
            "deltas": { "sanity": -1 }
          }
        }
      ]
    },

    {
      "id": "reef.lantern_glow",
      "depthRange": [26, 42],
      "zoneTags": ["reef"],
      "weight": 3,
      "oncePerRun": true,
      "title": "下面的光",
      "body": "礁壁底下，塔倒进去的地方，有光。\n它在转。慢慢地，一圈、一圈——\n像那盏灯还在扫。\n可岩石底下没有放灯的地方。",
      "tone": "cosmic",
      "options": [
        {
          "id": "go_toward",
          "label": "朝光游过去（理智 vs 50）",
          "check": {
            "stat": "sanity",
            "dc": 50,
            "onSuccess": {
              "text": "你停在岩壁前。光从石头另一侧扫过来，一圈，又一圈。\n你数到三圈，逼自己掉头。",
              "deltas": { "sanity": -6 },
              "oxygenTurnCost": 2,
              "loreEntry": "lore.old_lighthouse.the_light"
            },
            "onFailure": {
              "text": "你贴着岩壁往下，光始终差一臂远。\n等你回过神，灯照着你自己刚划过的水。氧气表在响。",
              "deltas": { "sanity": -12 },
              "oxygenTurnCost": 5
            }
          }
        },
        {
          "id": "turn_back",
          "label": "背过身离开",
          "outcome": {
            "text": "你转过身。光在背后继续转，不快不慢。",
            "deltas": { "sanity": -3 },
            "oxygenTurnCost": 1
          }
        }
      ]
    },

    {
      "id": "wreck.silted_hold",
      "depthRange": [45, 60],
      "zoneTags": ["wreck"],
      "weight": 7,
      "cooldown": 4,
      "title": "淤住的货舱",
      "body": "一艘大货船船头扎进沙里，货舱口朝下张着。\n淤泥灌了半舱，软得探不到底。\n灯柱里，泥面上还立着几只没被压垮的铜箍木桶。",
      "tone": "realistic",
      "options": [
        {
          "id": "pry_hoops",
          "label": "撬桶上的铜箍（体力 vs 14）",
          "check": {
            "stat": "stamina",
            "dc": 14,
            "onSuccess": {
              "text": "铜箍崩开，木桶塌成一摊朽屑——里面是几听没胀的罐头，和裹在油纸里的一截黄铜管件。",
              "oxygenTurnCost": 2,
              "loot": [
                { "itemId": "item.brass_fitting", "qty": [1, 1] },
                { "itemId": "item.canned_food", "qty": [1, 2], "chance": 0.6 }
              ]
            },
            "onFailure": {
              "text": "箍锈死了。你撬到一半，泥从舱顶塌下来，糊住半个灯柱。你退出去时呛了一口。",
              "oxygenTurnCost": 3,
              "deltas": { "stamina": -8 }
            }
          }
        },
        {
          "id": "dig_silt",
          "label": "在淤泥里掏一把（氧气 -2）",
          "outcome": {
            "text": "你把手插进泥里摸。冰冷，什么都抓不实——指尖最后碰到一块带棱的硬东西，是金属。",
            "oxygenTurnCost": 2,
            "loot": [
              { "itemId": "item.brass_fitting", "qty": [1, 1], "chance": 0.5 },
              { "itemId": "item.coral_shard", "qty": [1, 2], "chance": 0.4 }
            ]
          }
        },
        {
          "id": "skirt_hold",
          "label": "不下去，贴舱口绕过",
          "outcome": {
            "text": "你贴着舱口外缘游过去。泥面在你身下慢慢合上刚被灯惊起的纹路。",
            "oxygenTurnCost": 1
          }
        }
      ]
    },

    {
      "id": "cave.halocline",
      "depthRange": [48, 60],
      "zoneTags": ["cave"],
      "weight": 6,
      "cooldown": 5,
      "title": "盐线",
      "body": "灯柱往下，到某个深度忽然散开，像照进了毛玻璃。\n那是一层水——上面咸，下面更咸，交界处晃得人眼晕。\n那条线底下，水温陡降。",
      "tone": "realistic",
      "options": [
        {
          "id": "feel_wall_down",
          "label": "贴着岩壁慢慢下（体力 vs 13）",
          "check": {
            "stat": "stamina",
            "dc": 13,
            "onSuccess": {
              "text": "你一手搭着岩壁，顺它往下。毛玻璃那层从身侧滑过去，你始终知道哪边是上。",
              "oxygenTurnCost": 1,
              "loot": [
                { "itemId": "item.coral_shard", "qty": [1, 1], "chance": 0.4 }
              ]
            },
            "onFailure": {
              "text": "你松开了壁。那层晃水里没有上下——等你抓回岩石，已经多沉了几米，氧气表跳了一下。",
              "oxygenTurnCost": 3,
              "deltas": { "stamina": -5, "sanity": -2 }
            }
          }
        },
        {
          "id": "push_through_layer",
          "label": "直接穿过那层水（氧气 -2）",
          "outcome": {
            "text": "你穿过去。有一瞬，手在眼前裂成两半，又合上。线下面冷得贴骨，能见度反而清了。",
            "oxygenTurnCost": 2,
            "deltas": { "nitrogen": 3 }
          }
        },
        {
          "id": "stay_above",
          "label": "不下去，沿这条深度另找路（氧气 -1）",
          "outcome": {
            "text": "你停在线上方，横着找别的下口。背上凉了一阵。",
            "oxygenTurnCost": 1
          }
        }
      ]
    },

    {
      "id": "wreck.porthole",
      "depthRange": [50, 60],
      "zoneTags": ["wreck"],
      "weight": 4,
      "cooldown": 5,
      "oncePerRun": true,
      "title": "舷窗",
      "body": "深舱一侧嵌着一只黄铜舷窗，玻璃厚得发绿，居然没碎。\n你的灯一打上去——\n玻璃那边是亮的。是白天的、有阳光纹路的浅蓝海水。\n可这只窗的另一面，是塞满淤泥的舱壁。",
      "tone": "uncanny",
      "options": [
        {
          "id": "look_through",
          "label": "把脸贴上玻璃看（理智 vs 55）",
          "check": {
            "stat": "sanity",
            "dc": 55,
            "onSuccess": {
              "text": "你贴近。阳光纹路在玻璃里游动——再细看，那是你自己的灯，在老玻璃的层裂里散成了一片假的天光。你退开。",
              "oxygenTurnCost": 1,
              "deltas": { "sanity": -3 },
              "loreEntry": "lore.deep_water.the_window"
            },
            "onFailure": {
              "text": "你贴得太久。蓝水里有个影子游近，又游远——像人，又不太像。等你回过神，灯贴在玻璃上，氧气表在响。",
              "oxygenTurnCost": 3,
              "deltas": { "sanity": -9 }
            }
          }
        },
        {
          "id": "pry_ring",
          "label": "撬下舷窗的铜圈（氧气 -2）",
          "outcome": {
            "text": "你用刀柄沿铜圈一点点撬。圈松开的那一下，玻璃那边的光也灭了——像谁吹熄了它。",
            "oxygenTurnCost": 2,
            "loot": [{ "itemId": "item.brass_fitting", "qty": [1, 1] }],
            "deltas": { "sanity": -2 }
          }
        },
        {
          "id": "look_away",
          "label": "不看，游开",
          "outcome": {
            "text": "你别开灯柱，绕过那只窗。余光里它还亮着。",
            "deltas": { "sanity": -1 }
          }
        }
      ]
    },

    {
      "id": "cave.blue_floor",
      "depthRange": [52, 60],
      "zoneTags": ["cave"],
      "weight": 3,
      "cooldown": 6,
      "oncePerRun": true,
      "title": "洞底的蓝",
      "body": "你下到能下的最底。\n沙是冷的，水一丝不动——可沙底透着蓝。\n很淡，很匀，没有源头。像岩床底下埋着一盏灯，隔着几米的沙，还亮着。",
      "tone": "cosmic",
      "options": [
        {
          "id": "dig_for_source",
          "label": "扒开沙，看蓝从哪来（理智 vs 50）",
          "check": {
            "stat": "sanity",
            "dc": 50,
            "onSuccess": {
              "text": "你扒了一阵。蓝没有变近——它在更深的沙里，扒不到底。但你搅起的细沙里有星点的光，聚了又散：是沉在沙里的发光小虫。你逼自己停手。",
              "oxygenTurnCost": 2,
              "deltas": { "sanity": -6 },
              "loot": [{ "itemId": "item.coral_shard", "qty": [1, 2], "chance": 0.5 }],
              "loreEntry": "lore.deep_water.cold_light"
            },
            "onFailure": {
              "text": "你扒得停不下来。蓝始终差一层沙。等你回过神，你跪在一个自己挖出的坑里，坑壁齐整得不像手挖的，氧气表早过了红线。",
              "oxygenTurnCost": 5,
              "deltas": { "sanity": -12 }
            }
          }
        },
        {
          "id": "remember_and_leave",
          "label": "不碰，记住这片蓝，往回走",
          "outcome": {
            "text": "你把这片蓝收进记忆，退着往上。它在你脚下，不快不慢，匀匀地亮着。",
            "oxygenTurnCost": 1,
            "deltas": { "sanity": -3 }
          }
        }
      ]
    },

    {
      "id": "reef.barracuda",
      "depthRange": [
        26,
