            "loot": [{ "itemId": "item.brass_fitting", "qty": [1, 1], "chance": 0.5 }]
          }
        },
        {
          "id": "leave_locker",
          "label": "太挤，退出去",
          "outcome": {
            "text": "你看了一眼那坨随时会塌的链，退回过道。",
            "oxygenTurnCost": 1
