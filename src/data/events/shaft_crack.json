{
  "events": [
    {
      "id": "shaftcrack.mouth",
      "depthRange": [20, 34],
      "zoneTags": ["crack"],
      "weight": 8,
      "cooldown": 4,
      "title": "井口",
      "body": "礁盘上一道竖着的裂口。\n上面的光只够照到头几米，再往下是直的、黑的，连个落脚的横棱都没有。\n你贴着缝壁往下试了试——水越往下越凉。",
      "tone": "realistic",
      "options": [
        {
          "id": "drop_in",
          "label": "侧身顺着缝壁沉下去",
          "outcome": {
            "text": "你收起两条胳膊，让自己贴着缝壁往下走。头顶那道亮线慢慢缩成一根针。"
          }
        },
        {
          "id": "sound_wall",
          "label": "先用刀背磕一下岩壁，听落底",
          "outcome": {
            "text": "你拿刀背磕了磕缝壁。回声很闷，落得很深，半天没个底——这道井比看上去要长。你记下这一点，再往下。",
            "oxygenTurnCost": 1
          }
        },
        {
          "id": "scrape_rim",
          "label": "沿井口边缘摸一圈再走",
          "outcome": {
            "text": "你绕着井口摸了一圈，缝边松动的石壳里抠下几块带棱的硬料。",
            "oxygenTurnCost": 1,
            "loot": [
              { "itemId": "item.flint_nodule", "qty": [1, 2], "chance": 0.7 },
              { "itemId": "item.coral_shard", "qty": [1, 1], "chance": 0.4 }
            ]
          }
        }
      ]
    },
    {
      "id": "shaftcrack.wedged_gear",
      "depthRange": [24, 50],
      "zoneTags": ["crack"],
      "weight": 6,
      "cooldown": 5,
      "title": "卡在缝里的东西",
      "body": "下行到一处，缝壁突然夹紧。\n夹缝里横着卡了个东西——一团早年沉下来、又被水流硬塞进缝的旧网具，缠着半截发锈的金属件。\n它卡得很死，但还够得着。",
      "tone": "realistic",
      "options": [
        {
          "id": "cut_free",
          "label": "割开缠网，取里面的金属件",
          "visibleIf": { "kind": "hasCapability", "capability": "cut" },
          "outcome": {
            "exertion": true,
            "text": "你顺着缠死的结口割下去。网一松，那截铜件连同半张还能用的网一起脱出来，落进你手里。",
            "oxygenTurnCost": 1,
            "loot": [
              { "itemId": "item.brass_fitting", "qty": [1, 1], "chance": 0.8 },
              { "itemId": "item.old_fishing_net", "qty": [1, 1], "chance": 0.6 }
            ]
          }
        },
        {
          "id": "wrench_out",
          "label": "硬把它从缝里拽出来",
          "check": {
            "stat": "stamina",
            "dc": 13,
            "onSuccess": {
              "text": "你两脚抵住缝壁，使了一记长劲。东西闷响一声松了，连泥带锈一起脱出来。",
              "oxygenTurnCost": 2,
              "loot": [
                { "itemId": "item.brass_fitting", "qty": [1, 1], "chance": 0.7 },
                { "itemId": "item.old_fishing_net", "qty": [1, 1], "chance": 0.4 }
              ]
            },
            "onFailure": {
              "text": "你拽得太猛，缝壁上一层松壳哗地塌下来，呛起一团泥。东西没出来，你的胳膊倒在缝棱上划开一道。",
              "oxygenTurnCost": 2,
              "deltas": { "stamina": -6 }
            }
          }
        },
        {
          "id": "leave_gear",
          "label": "不值当，继续往下",
          "outcome": {
            "text": "你由它卡着。这点东西不值得在窄缝里耗气。",
            "oxygenTurnCost": 1
          }
        }
      ]
    },
    {
      "id": "shaftcrack.pinch",
      "depthRange": [30, 60],
      "zoneTags": ["crack"],
      "weight": 6,
      "cooldown": 3,
      "title": "夹口",
      "body": "缝在这里收成一道夹口，比肩还窄。\n对面能看见它又松开、继续往下——只是中间这一段，得把气瓶侧过来、贴着脸蹭过去。",
      "tone": "realistic",
      "options": [
        {
          "id": "squeeze",
          "label": "卸力侧身，贴着脸蹭过去",
          "check": {
            "stat": "stamina",
            "dc": 14,
            "onSuccess": {
              "text": "你把气瓶转到侧面，吐掉一口气让胸腔瘪下去，一寸一寸蹭过夹口。出来时后背蹭得生疼，但过来了。",
              "oxygenTurnCost": 2
            },
            "onFailure": {
              "text": "你卡在最窄那段，进退都动不了。一阵憋闷顶上来，你只能慢慢吐气、把自己一点点退回去，重来一次才挤过来。",
              "oxygenTurnCost": 4,
              "deltas": { "stamina": -5 }
            }
          }
        },
        {
          "id": "find_around",
          "label": "退回去，绕另一条缝",
          "outcome": {
            "text": "你不跟这道夹口较劲，退回上一个岔口，另寻一条松些的缝往下。多花了些气，但身上没添新伤。",
            "oxygenTurnCost": 3
          }
        }
      ]
    },
    {
      "id": "shaftcrack.listener",
      "depthRange": [35, 78],
      "zoneTags": ["crack"],
      "weight": 6,
      "cooldown": 0,
      "title": "缝里有东西在听",
      "body": "灯扫过侧壁的一道横缝——\n里面盘着什么，很长，皮泛着反光，没有眼睛。\n它对着你的方向慢慢转过来。它在用听的。",
      "tone": "uncanny",
      "options": [
        {
          "id": "draw_knife",
          "label": "亮刀防身",
          "visibleIf": { "kind": "hasEquipment", "slot": "tool" },
          "outcome": {
            "text": "刀出鞘的那一声金属响里，它弹了出来。",
            "triggerCombatId": "combat.blind_eel_solo"
          }
        },
        {
          "id": "hold_breath",
          "label": "屏住呼吸，等它缩回去",
          "hideCheck": true,
          "check": {
            "stat": "stamina",
            "dc": 13,
            "onSuccess": {
              "text": "你把气泡彻底停了几个回合。它在水里转着头，找不到落点，又慢慢盘回横缝深处。",
              "oxygenTurnCost": 3
            },
            "onFailure": {
              "text": "你憋不住，一串气泡漏出来。它顺着那点动静直扑过来。",
              "triggerCombatId": "combat.blind_eel_solo"
            }
          }
        },
        {
          "id": "back_off",
          "label": "倒着踢水退开",
          "outcome": {
            "text": "你倒着退出它那段缝。它没追，但你下井的一路上，都觉得那段黑在听着你的气泡。",
            "oxygenTurnCost": 2,
            "deltas": {"stamina": -3 }
          }
        }
      ]
    },
    {
      "id": "shaftcrack.vein",
      "depthRange": [40, 78],
      "zoneTags": ["crack"],
      "weight": 5,
      "cooldown": 5,
      "title": "井壁的矿脉",
      "body": "灯下，井壁裂面上嵌着一道色泽不一样的脉络，结着一排深色的硬瘤——是被这道竖缝劈开、露出来的一截矿脉。\n够得着，但得腾出一只手在缝里凿。",
      "tone": "realistic",
      "options": [
        {
          "id": "drill_vein",
          "label": "用岩凿撬下结瘤",
          "visibleIf": { "kind": "hasCapability", "capability": "mine" },
          "outcome": {
            "exertion": true,
            "text": "你把岩凿抵进瘤根，一下一下撬。深色的硬瘤接连脱落，沉甸甸坠进网兜。",
            "oxygenTurnCost": 2,
            "loot": [
              { "itemId": "item.iron_concretion", "qty": [1, 2], "chance": 0.85 },
              { "itemId": "item.manganese_nodule", "qty": [1, 1], "chance": 0.5 }
            ]
          }
        },
        {
          "id": "pry_loose",
          "label": "拿手边的硬物硬抠几块",
          "outcome": {
            "text": "没有趁手的凿子，你只能拿刀柄硬磕，抠下两三块松的。剩下嵌得太深的，留给下一个带家伙来的人。",
            "oxygenTurnCost": 2,
            "loot": [
              { "itemId": "item.flint_nodule", "qty": [1, 1], "chance": 0.6 }
            ]
          }
        },
        {
          "id": "skip_vein",
          "label": "记下位置，先不耽搁",
          "outcome": {
            "text": "你把这道脉的深度记在心里，没停。井底的气比石头要紧。",
            "oxygenTurnCost": 1
          }
        }
      ]
    },
    {
      "id": "shaftcrack.silt_fall",
      "depthRange": [22, 55],
      "zoneTags": ["crack"],
      "weight": 5,
      "cooldown": 4,
      "title": "塌下来的泥",
      "body": "你刚蹭过一处松壁，上方就簌簌落下一片陈年的泥。\n灯光被泥团搅成一团黄雾，缝壁、上下、来路，一时全糊住了。",
      "tone": "realistic",
      "options": [
        {
          "id": "hold_still",
          "label": "贴住缝壁不动，等泥沉下去",
          "outcome": {
            "text": "你按住一处缝棱，停了呼吸，让那团黄雾慢慢往下沉。视野一点点回来，你还在原来的方向上。",
            "oxygenTurnCost": 2
          }
        },
        {
          "id": "push_through",
          "label": "凭感觉摸着往下穿过去",
          "outcome": {
            "text": "你闭着没用的眼睛，单凭手底缝壁的走向往下摸。等泥散开，方向没乱。",
            "oxygenTurnCost": 2
          }
        }
      ]
    },
    {
      "id": "shaftcrack.bottom_dark",
      "depthRange": [62, 78],
      "zoneTags": ["crack"],
      "weight": 4,
      "cooldown": 0,
      "title": "井底的横走",
      "body": "竖缝在这里到了底，往一侧横着铺开。\n灯打到尽头，那里的黑不反光，像把光吞了进去。\n你停了一下——刚才那串气泡的回声，落得比这条横道该有的长度要久。",
      "tone": "cosmic",
      "options": [
        {
          "id": "lamp_forward",
          "label": "把灯举到最亮，照清楚横道尽头",
          "outcome": {
            "text": "你把灯调到最亮。光照过去，尽头还是只有更深一层的黑，连块实在的岩面都没还给你。你收回灯，没再往那边去。",
            "oxygenTurnCost": 2
          }
        },
        {
          "id": "mark_turn",
          "label": "在岔口刻个记号，原路退回去",
          "outcome": {
            "text": "你在转角的岩面上刻下一道印，转身往回。回程那口气你算得很紧，没敢回头去看那段不反光的黑。",
            "oxygenTurnCost": 2
          }
        } ]
    }
  ]
}
