{
  "events": [
    {
      "id": "blue_caves.geode_vein",
      "depthRange": [
        12,
        55
      ],
      "zoneTags": [
        "cave"
      ],
      "weight": 8,
      "poiId": "poi.anchor.blue_caves",
      "title": "壁里的一窝晶",
      "body": "灯扫过洞壁，有一处反光不一样。\n凑近看，是嵌在石里的一窝晶簇——灰壳裹着，剖面朝外，紫蓝的尖一层叠一层。这洞就这么大，矿脉数得过来；这一窝凿走，这面壁往后就只剩石。",
      "tone": "realistic",
      "options": [
        {
          "id": "pry_geode",
          "label": "用凿子撬下这一窝晶簇",
          "visibleIf": {
            "kind": "hasCapability",
            "capability": "mine"
          },
          "outcome": {
            "exertion": true,
            "text": "你把凿尖卡进晶壳和石的接缝，一点点撬。壳裂开，整窝晶连着底座落进你手里，断面还是新的。\n你回头看那面壁——嵌晶的地方留了个浅坑，灰白的石，再没有第二窝。这条脉，到此为止。",
            "oxygenTurnCost": 2,
            "loot": [
              {
                "itemId": "item.bluecave_geode",
                "qty": [
                  1,
                  2
                ]
              }
            ]
          }
        },
        {
          "id": "leave_geode",
          "label": "记下位置，空手走",
          "outcome": {
            "text": "你没带能凿它的家伙，徒手在壳上抠了两下，只蹭下一层石粉。\n你把这处记进写字板：方位、深度、那一窝晶的成色。它跑不了，等你带对工具再来。",
            "oxygenTurnCost": 1
          }
        }
      ]
    },
    {
      "id": "blue_caves.gallery_crust_seam",
      "depthRange": [
        14,
        32
      ],
      "zoneTags": [
        "cave"
      ],
      "weight": 8,
      "poiId": "poi.anchor.flat_gallery",
      "title": "顶上的结壳",
      "body": "横岩廊几乎不往下走，灯往上一抬，廊顶贴着一长条灰白的硬壳，断面一层层叠着——是水年复一年贴上去结的。\n水浅，没有涌流，站得稳，使得上劲。这条廊就这么长，结壳的脉数得过来；剥光一段，那面顶往后就只剩素石。",
      "tone": "realistic",
      "options": [
        {
          "id": "pry_crust",
          "label": "用岩凿沿结壳剥一段下来",
          "visibleIf": {
            "kind": "hasCapability",
            "capability": "mine"
          },
          "outcome": {
            "exertion": true,
            "text": "凿尖卡进壳和石的缝里，顺着层理一撬，整片硬壳连着剥落，断面还是新的土黄。\n你回头看那段顶——剥过的地方留下一条素石的浅痕。这条脉，到此为止。",
            "oxygenTurnCost": 2,
            "loot": [
              {
                "itemId": "item.gallery_crust",
                "qty": [
                  1,
                  2
                ]
              }
            ]
          }
        },
        {
          "id": "measure_gallery",
          "label": "贴着顶量一量这条廊还往里多远",
          "outcome": {
            "text": "你贴着廊顶游了一段，结壳一路没断。廊不往下，只往里，里到灯照不见头。\n你记下：来路有多长，回头的路就有多长。气还剩大半，掉头。",
            "oxygenTurnCost": 1
          }
        },
        {
          "id": "leave_crust",
          "label": "没带凿子，记下位置走",
          "outcome": {
            "text": "你徒手在结壳上抠了两下，只起一层粉。记下方位和深度——它跑不了，带对家伙再来。",
            "oxygenTurnCost": 1
          }
        }
      ]
    }
  ]
}
