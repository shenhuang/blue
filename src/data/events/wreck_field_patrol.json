{
  "events": [
    {
      "id": "wreck_graveyard.patrol_stir",
      "depthRange": [22, 46],
      "zoneTags": ["wreck"],
      "weight": 5,
      "cooldown": 6,
      "title": "船骸间的动静",
      "body": "你停在两道断裂的龙骨之间。\n锈铁的另一侧有什么在挪动——不快，但有方向。一点冷光，或是硬壳刮过钢板的轻响，你分不清是哪一种。\n沉船墓园从不空着。无论那是什么，它已经认准了你这边。",
      "tone": "uncanny",
      "options": [
        {
          "id": "face_it",
          "label": "握紧刀，转过身正对它",
          "visibleIf": { "kind": "hasEquipment", "slot": "tool" },
          "outcome": {
            "text": "你把刀横在身前，等那团动静从锈影里出来。",
            "triggerCombatId": "combat.wreck_field_patrol"
          }
        },
        {
          "id": "slip_away",
          "label": "贴着船壳，慢慢退出这道缝",
          "check": {
            "stat": "stamina",
            "dc": 12,
            "onSuccess": {
              "text": "你压住每一次踢动，顺着船壳的阴影退了出去。那点动静停在原处，没有跟来。",
              "oxygenTurnCost": 2,
              "deltas": { "sanity": -2 }
            },
            "onFailure": {
              "text": "你的脚蹼蹭到一截垂下的缆绳，锈屑簌簌落下。那边的动静一下有了方向——朝你来了。",
              "triggerCombatId": "combat.wreck_field_patrol"
            }
          }
        },
        {
          "id": "kill_light",
          "label": "关灯，屏住，赌它认不出你",
          "outcome": {
            "text": "你掐了灯。黑里只剩自己的心跳，和那团动静擦过钢板的声音——越来越近，又……偏开了。你慢慢把那口气放出来。",
            "oxygenTurnCost": 1,
            "deltas": { "sanity": -4 }
          }
        }
      ]
    }
  ]
}
