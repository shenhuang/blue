            "stat": "stamina",
            "dc": 13,
            "onSuccess": {
              "text": "你在网绷向深处之前、网眼还结实的上半截下刀。割下好一段网；拖网船甲板上滚出来的几听罐头也在手边。\n你没顺着网往下去看，是什么把它拉得那么紧。",
              "oxygenTurnCost": 2,
              "loot": [
                { "itemId": "item.old_fishing_net", "qty": [1, 1] },
                { "itemId": "item.canned_food", "qty": [1, 2], "chance": 0.5 }
              ]
            },
            "onFailure": {
              "text": "刀卡在网眼里。整张网猛地一抖，往下又吃进一截，把你的手腕朝深水那边拽了一掌宽，你才割脱开。\n你退回浅处，手是空的。",
              "oxygenTurnCost": 3,
              "deltas": { "stamina": -7 }
            }
          }
        },
