          },
          "outcome": { "advanceOutpostId": "outpost.reef_deep" }
        },
        {
          "id": "power_on",
          "label": "通电点亮（章鱼角喙×2·黄铜配件×2 ＋ 140 金）",
          "visibleIf": {
            "kind": "all",
