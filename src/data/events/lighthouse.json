          "id": "ferry_parts",
          "label": "运来支柱与浮筒部件（黄铜配件×3·蛛蟹甲壳×2 ＋ 90 金）",
          "visibleIf": {
            "kind": "all",
            "of": [
              { "kind": "hasFlag", "flag": "flag.outpost.reef_deep.s1" },
              { "kind": "notHasFlag", "flag": "flag.outpost.reef_deep.s2" }
